# Backend secrets (copy to .env and fill values)

# Adzuna API (required for job fetching)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# Groq API (optional; only used if you enabled Groq features)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (required for resume analysis if enabled)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Auth
VETERANHIRE_JWT_SECRET=replace_me_with_a_long_random_string

